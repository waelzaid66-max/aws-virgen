# BANCO Web — staging overrides (copy to .env.local on staging hosts)
# Production keeps NEXT_PUBLIC_WEB_SEARCH_LIVE=false and MAP=false by default.

NEXT_PUBLIC_SITE_URL=https://staging-web.example.com
NEXT_PUBLIC_API_URL=https://staging-api.example.com

# Staging: enable live browse against staging API
NEXT_PUBLIC_WEB_SEARCH_LIVE=true
NEXT_PUBLIC_WEB_SEARCH_MAP=true
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

NEXT_PUBLIC_MARKET_URL=https://staging-market.example.com
NEXT_PUBLIC_ADMIN_URL=
NEXT_PUBLIC_APP_ANDROID_URL=
NEXT_PUBLIC_APP_IOS_URL=

# Optional English mirror (hreflang en) when a separate EN site exists
NEXT_PUBLIC_SITE_URL_EN=

NEXT_PUBLIC_SEARCH_ENABLED=true
NEXT_PUBLIC_SEARCH_ANALYTICS_MODE=debug
