# BANCO Web — environment (copy to .env.local for local dev)

# Public API base (browser). Dev: Next rewrites /api/* and /l/* to this host.
# Production: same-origin via reverse proxy (nginx).
NEXT_PUBLIC_API_URL=http://localhost:5000

# Linked surfaces (optional — hub cards / footer links)
NEXT_PUBLIC_MARKET_URL=
NEXT_PUBLIC_ADMIN_URL=
NEXT_PUBLIC_APP_ANDROID_URL=
NEXT_PUBLIC_APP_IOS_URL=

# Site URL for canonical/OG/hreflang (set in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional English site mirror for hreflang `en` (leave empty = ar-EG only)
NEXT_PUBLIC_SITE_URL_EN=

# Rollback: false -> search page shows hub links only (no filters/live path).
NEXT_PUBLIC_SEARCH_ENABLED=true

# Feature flag: keep false by default for safe staged rollout.
# true  -> enable live search integration path
# false -> keep typed mock search path
NEXT_PUBLIC_WEB_SEARCH_LIVE=false

# Search analytics mode:
# debug -> logs + browser event bridge (default safe mode)
# off   -> disables adapter side effects (events still emitted by telemetry bridge)
NEXT_PUBLIC_SEARCH_ANALYTICS_MODE=debug

# Map preview toggle (list/map via ?view=map). Keep false by default.
# true  -> show list/map toggle and map cluster preview panel
# false -> list-only search shell
NEXT_PUBLIC_WEB_SEARCH_MAP=false

# Docker / Cloud Run: NEXT_STANDALONE=true + deploy/aws/Dockerfile.banco-web

# Google Maps JavaScript API key (optional — without it, map view uses CSS preview).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
