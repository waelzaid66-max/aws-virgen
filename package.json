{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "preinstall": "node scripts/preinstall-enforce-pnpm.mjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "lint": "eslint scripts --max-warnings 0",
    "lint:report": "eslint scripts artifacts/api-server/src lib/db/src",
    "confidence": "node scripts/production-confidence-check.mjs"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^14.0.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {}
}
